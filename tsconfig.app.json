{
  "compilerOptions": {
   //  "target": "ES2023",
   //  "lib": ["ES2023", "DOM"],
   //  "module": "ESNext",
   //  "moduleResolution": "bundler",

    "jsx": "react-jsx",
    "types": ["vite/client"],

    "allowImportingTsExtensions": true,
    "moduleDetection": "force",

    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true
  },
  "include": ["src"]
}